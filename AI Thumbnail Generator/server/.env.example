# Session Configuration
SESSION_SECRET=your_session_secret_here

# Database Configuration
MONGODB_URI=your_mongodb_connection_string

# Gemini API (for prompt refinement)
GEMINI_API_KEY=your_gemini_api_key

# Cloudinary Configuration (for image hosting)
CLOUDINARY_URL=cloudinary://account_id:api_key@cloud_name

# Hugging Face Configuration (for FLUX.1 image generation)
# Get your token from: https://huggingface.co/settings/tokens
HF_ACCESS_TOKEN=your_huggingface_access_token
